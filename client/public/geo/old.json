{
    "id": "coastline",
    "type": "line",
    "paint": {
        "line-blur": 0.5,
        "line-color": "#FFECE5",
        "line-width": {
            "stops": [
                [0, 2],
                [6, 6],
                [14, 9],
                [22, 18]
            ]
        }
    },
    "filter": ["all"],
    "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
    },
    "source": "maplibre",
    "maxzoom": 24,
    "minzoom": 0,
    "source-layer": "countries"
}
